ENGINE_SERVICE_NAME=aibase-local-engine
ENGINE_STORAGE_ROOT=./data
ENGINE_EXPORTS_ROOT=./exports

# rule | hf
ENGINE_MODEL_MODE=hf
ENGINE_HF_TASK=text2text-generation
ENGINE_HF_MODEL_ID=google/flan-t5-base
ENGINE_HF_DEVICE=cpu
ENGINE_HF_LOCAL_FILES_ONLY=true
ENGINE_HF_MAX_NEW_TOKENS=256
ENGINE_HF_TEMPERATURE=0.2
ENGINE_HF_TOP_P=0.95
ENGINE_HF_REPETITION_PENALTY=1.05

ENGINE_DEFAULT_PROFILE=assistant_general
ENGINE_DEFAULT_SYSTEM_PROMPT=Eres un asistente local. Responde de forma clara y breve.

ENGINE_QUALITY_GATE_ENABLED=true
ENGINE_QUALITY_GATE_MIN_SAMPLES=3
ENGINE_QUALITY_GATE_MIN_SUCCESS_RATE=0.6
ENGINE_QUALITY_GATE_MAX_FALLBACK_RATE=0.4
ENGINE_QUALITY_GATE_MAX_AVG_LATENCY_MS=25000
