DB_SERVER=SERVIDOR_BASE_DE_DATOS,PUERTO
DB_NAME=NOMBRE_BASE_DE_DATOS
DB_USER=USUARIO_DE_BASE_DE_DATOS
DB_PASSWORD=CONTRASEÑA_DE_BASE_DE_DATOS
DB_TRUST_CERT=True

JWT_SECRET=CLAVE_SUPER_SECRETA
JWT_ISSUER=systembase
JWT_AUDIENCE=systembase
JWT_EXPIRE_MINUTES=120

## Engine IA (Python/FastAPI)
AIBASE_ENGINE_URL=http://localhost:8010
AIBASE_ENGINE_URLS=http://localhost:8010,http://localhost:8011
AIBASE_ENGINE_TIMEOUT_SECONDS=120
AIBASE_ENGINE_MOCK=false

## Model service directo (opcional: ollama/openai)
# Provider: engine | ollama | openai
AIBASE_MODEL_PROVIDER=engine
AIBASE_MODEL_BASE_URL=http://localhost:11434
AIBASE_MODEL_PATH=/api/chat
AIBASE_MODEL_NAME=llama3.2:3b
AIBASE_MODEL_TEMPERATURE=0.2
AIBASE_MODEL_MAX_TOKENS=512
AIBASE_MODEL_TOP_P=0.95
AIBASE_MODEL_REPETITION_PENALTY=1.05
AIBASE_MODEL_TASK=
AIBASE_MODEL_LOCAL_FILES_ONLY=true
AIBASE_MODEL_TIMEOUT_SECONDS=120
AIBASE_MODEL_SYSTEM_PROMPT=
AIBASE_MODEL_API_KEY=
AIBASE_MODEL_API_KEY_ENV=OPENAI_API_KEY

## Gate de calidad previo a deploy (basado en métricas recientes de inferencia)
AIBASE_QUALITY_GATE_ENABLED=true
AIBASE_QUALITY_GATE_MIN_SAMPLES=3
AIBASE_QUALITY_GATE_MIN_SUCCESS_RATE=0.6
AIBASE_QUALITY_GATE_MAX_FALLBACK_RATE=0.4
AIBASE_QUALITY_GATE_MAX_AVG_LATENCY_MS=25000

## Endpoint esperado al desplegar
AIBASE_DEPLOY_ENDPOINT=http://localhost:5177
AIBASE_DEPLOY_HEALTH=http://localhost:5036/api/v1/dev/ping

## Docker control (desde UI en Development)
# Si está vacío usa ../docker/docker-compose.yml
AIBASE_DOCKER_COMPOSE_FILE=
AIBASE_DOCKER_PROJECT=aibase-stack
AIBASE_DOCKER_COMMAND_TIMEOUT_SECONDS=45
